APP_NAME=TasteForge AI
APP_ENV=dev
# Local default. Uses SQLite with deterministic vector ranking in Python.
DATABASE_URL=sqlite:///./data/tasteforge.db
# Production-style option. Requires PostgreSQL with pgvector and requirements-db.txt.
# Local Docker pgvector:
#   docker compose -f docker-compose.pgvector.yml up -d --build
#   pip install -r requirements.txt -r requirements-db.txt
# DATABASE_URL=postgresql://tasteforge:tasteforge@localhost:15432/tasteforge
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_LOCAL_REST_API_KEY=
